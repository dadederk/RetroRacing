    "paywall_giving_back_body": {
      "extractionState": "manual",
      "localizations": {
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "El 10% dels ingressos es destinen a **AMMEC**, una associació que promou l'autonomia i la integració social de persones amb discapacitats físiques, donant suport a les famílies i fomentant la comunitat."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "10% of proceeds go to **AMMEC**, an association that promotes autonomy and social integration for people with physical disabilities, supporting families and fostering community."
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "10% of proceeds go to **AMMEC**, an association that promotes autonomy and social integration for people with physical disabilities, supporting families and fostering community."
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "10% of proceeds go to **AMMEC**, an association that promotes autonomy and social integration for people with physical disabilities, supporting families and fostering community."
