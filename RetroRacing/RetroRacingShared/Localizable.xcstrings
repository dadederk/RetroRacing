            "value": "Plays all safe lanes at once as a chord."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Reproduce todos los carriles seguros a la vez como un acorde."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Spielt alle sicheren Spuren gleichzeitig als Akkord."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Speelt alle veilige banen tegelijk als een akkoord."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Riproduce tutte le corsie sicure insieme come un accordo."
          }
        },
        "fr": {
          "stringUnit": {
