    "tutorial_audio_move_style_description_lane_confirmation": {
      "extractionState": "manual",
      "localizations": {
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Reproduïx només la nota del carril de destinació quan et mous a l'esquerra o a la dreta, perquè puguis fer-la coincidir amb la pista d'àudio."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Plays only the destination lane note, as you move left or right, so you can match it with the audio cue."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Reproduce solo la nota del carril de destino al moverte a izquierda o derecha, para que puedas hacerla coincidir con la pista de audio."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Plays only the destination lane note, as you move left or right, so you can match it with the audio cue."
