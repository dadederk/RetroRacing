          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Plays lane confirmation followed by a success or fail tone."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Reproduce la confirmación de carril y después un tono de éxito o error."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Spielt Spurbestätigung gefolgt von Erfolgs- oder Fehlerton."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Speelt baansbevestiging gevolgd door een succes- of fouttoon."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Riproduce la conferma di corsia seguita da un tono di successo o errore."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Joue la confirmation de voie suivie d'un ton de succès ou d'échec."
          }
        }
      }
    },
    "tutorial_audio_move_style_description_lane_confirmation": {
      "extractionState": "manual",
      "localizations": {
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Reproduïx només la nota del carril de destinació quan et mous a l'esquerra o a la dreta, perquè puguis fer-la coincidir amb la pista d'àudio."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Plays only the destination lane note, as you move left or right, so you can match it with the audio cue."
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "Plays only the destination lane note, as you move left or right, so you can match it with the audio cue."
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Plays only the destination lane note, as you move left or right, so you can match it with the audio cue."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Plays only the destination lane note, as you move left or right, so you can match it with the audio cue."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Reproduce solo la nota del carril de destino al moverte a izquierda o derecha, para que puedas hacerla coincidir con la pista de audio."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Spielt nur die Zielspur-Note beim Bewegen nach links oder rechts, damit du sie mit dem Audio-Hinweis abgleichen kannst."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Speelt alleen de bestemmingsbaan-noot wanneer je naar links of rechts beweegt, zodat je die kunt matchen met de audio-aanwijzing."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Riproduce solo la nota della corsia di destinazione quando ti muovi a sinistra o a destra, così puoi abbinarla al segnale audio."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Joue uniquement la note de la voie de destination quand tu te déplaces à gauche ou à droite, pour la faire correspondre à l'indice audio."
          }
        }
      }
    },
