    "paywall_limit_notice": {
      "extractionState": "manual",
      "localizations": {
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Parada als boxes! Has esgotat totes les partides d'avui. Torna demà per a més partides gratuïtes. O fes-te il·limitat: un cafè per a mi, partides il·limitades per a tu!"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pit stop! You've used up all your plays for today. Come back tomorrow for more free plays. Or go unlimited: One coffee for me, unlimited plays for you!"
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "Pit stop! You've used up all your plays for today. Come back tomorrow for more free plays. Or go unlimited: One coffee for me, unlimited plays for you!"
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Pit stop! You've used up all your plays for today. Come back tomorrow for more free plays. Or go unlimited: One coffee for me, unlimited plays for you!"
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Pit stop! You've used up all your plays for today. Come back tomorrow for more free plays. Or go unlimited: One coffee for me, unlimited plays for you!"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¡Parada en boxes! Has agotado todas tus partidas de hoy. Vuelve mañana para más partidas gratuitas. ¿O hazte ilimitado? Un café para mí, partidas ilimitadas para ti."
          }
        }
      }
    },
