    "paywall_avatar_accessibility_label": {
      "extractionState": "manual",
      "localizations": {
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Retrat en píxels d'un home somrient amb barba, gorra plana i jersei marí, sobre una pista de carreres retro amb graderies, llums de sortida i cotxets verds en un estil de joc de 16 bits colorit."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pixel-art portrait of a smiling, bearded man wearing a flat cap and navy sweater, set against a retro racing track with grandstands, starting lights, and tiny green cars in a colorful 16-bit game style."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Retrato en píxeles de un hombre sonriente con barba, gorra plana y jersey marino, sobre una pista de carreras retro con gradas, semáforo de salida y pequeños coches verdes en un estilo de juego de 16 bits colorido."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Pixel-art portrait of a smiling, bearded man wearing a flat cap and navy sweater, set against a retro racing track with grandstands, starting lights, and tiny green cars in a colourful 16-bit game style."
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "Pixel-art portrait of a smiling, bearded man wearing a flat cap and navy sweater, set against a retro racing track with grandstands, starting lights, and tiny green cars in a colourful 16-bit game style."
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Pixel-art portrait of a smiling, bearded man wearing a flat cap and navy sweater, set against a retro racing track with grandstands, starting lights, and tiny green cars in a colorful 16-bit game style."
          }
        }
      }
    },
    "paywall_caption_coffee": {
      "extractionState": "manual",
      "localizations": {
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Hola! Soc la Dani. Considera desbloquejar partides il·limitades com una manera d'invitar-me a un cafè. Estar ben cafeïnada m'ajuda a continuar construint noves funcionalitats que espere que t'agraden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hi! I'm Dani. Consider unlocking Unlimited Plays as a way to get me a coffee. Being caffeinated helps me keep building new features that I hope you'll love."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¡Hola! Soy Dani. Plantéate desbloquear partidas ilimitadas como una forma de invitarme a un café. Estar bien cafeinada me ayuda a seguir construyendo nuevas funciones que espero que te encanten."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Hi! I'm Dani. Consider unlocking Unlimited Plays as a way to get me a coffee. Being caffeinated helps me keep building new features that I hope you'll love."
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "Hi! I'm Dani. Consider unlocking Unlimited Plays as a way to get me a coffee. Being caffeinated helps me keep building new features that I hope you'll love."
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Hi! I'm Dani. Consider unlocking Unlimited Plays as a way to get me a coffee. Being caffeinated helps me keep building new features that I hope you'll love."
          }
        }
      }
    },
