    "paywall_limit_notice": {
      "extractionState": "manual",
      "localizations": {
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Parada als boxes! Has esgotat totes les partides d'avui. Torna demà per a més partides gratuïtes. O fes-te il·limitat: un cafè per a mi, partides il·limitades per a tu!"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pit stop! You've used up all your plays for today. Come back tomorrow for more free plays. Or go unlimited: One coffee for me, unlimited plays for you!"
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "Pit stop! You've used up all your plays for today. Come back tomorrow for more free plays. Or go unlimited: One coffee for me, unlimited plays for you!"
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Pit stop! You've used up all your plays for today. Come back tomorrow for more free plays. Or go unlimited: One coffee for me, unlimited plays for you!"
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Pit stop! You've used up all your plays for today. Come back tomorrow for more free plays. Or go unlimited: One coffee for me, unlimited plays for you!"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¡Parada en boxes! Has agotado todas tus partidas de hoy. Vuelve mañana para más partidas gratuitas. ¿O hazte ilimitado? Un café para mí, partidas ilimitadas para ti."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Boxenstopp! Du hast alle Spiele für heute verbraucht. Komm morgen wieder für mehr Gratis-Spiele. Oder geh unbegrenzt: Ein Kaffee für mich, unbegrenzte Spiele für dich!"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pitstop! Je hebt al je runs voor vandaag opgebruikt. Kom morgen terug voor meer gratis runs. Of ga onbeperkt: een koffie voor mij, onbeperkt spelen voor jou!"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Pit stop! Hai esaurito tutte le partite di oggi. Torna domani per altre partite gratuite. Oppure vai senza limiti: un caffè per me, partite illimitate per te!"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Arrêt aux stands ! Tu as utilisé toutes tes parties du jour. Reviens demain pour plus de parties gratuites. Ou passe en illimité : un café pour moi, des parties illimitées pour toi !"
          }
        }
      }
    },
