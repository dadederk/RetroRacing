    "paywall_avatar_accessibility_label": {
      "extractionState": "manual",
      "localizations": {
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Retrat en píxels d'un home somrient amb barba, gorra plana i jersei marí, sobre una pista de carreres retro amb graderies, llums de sortida i cotxets verds en un estil de joc de 16 bits colorit."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pixel-art portrait of a smiling, bearded man wearing a flat cap and navy sweater, set against a retro racing track with grandstands, starting lights, and tiny green cars in a colorful 16-bit game style."
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "Pixel-art portrait of a smiling, bearded man wearing a flat cap and navy sweater, set against a retro racing track with grandstands, starting lights, and tiny green cars in a colourful 16-bit game style."
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Pixel-art portrait of a smiling, bearded man wearing a flat cap and navy sweater, set against a retro racing track with grandstands, starting lights, and tiny green cars in a colorful 16-bit game style."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Pixel-art portrait of a smiling, bearded man wearing a flat cap and navy sweater, set against a retro racing track with grandstands, starting lights, and tiny green cars in a colourful 16-bit game style."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Retrato en píxeles de un hombre sonriente con barba, gorra plana y jersey marino, sobre una pista de carreras retro con gradas, semáforo de salida y pequeños coches verdes en un estilo de juego de 16 bits colorido."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Pixel-Art-Porträt eines lächelnden, bärtigen Mannes mit Flat Cap und marineblauem Pullover, vor einer Retro-Rennstrecke mit Tribünen, Startampeln und winzigen grünen Autos im bunten 16-Bit-Spielstil."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pixelart-portret van een glimlachende, bebaarde man met een platte pet en marineblauwe trui, tegen een retro-racecircuit met tribunes, startlichten en kleine groene auto's in een kleurrijke 16-bit gamestijl."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ritratto pixel art di un uomo sorridente con barba, berretto piatto e maglione blu navy, su un circuito retro con tribune, semaforo di partenza e piccole auto verdi in uno stile di gioco 16 bit colorato."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Portrait en pixel art d'un homme souriant barbu, casquette plate et pull bleu marine, sur un circuit rétro avec tribunes, feux de départ et petites voitures vertes dans un style de jeu 16 bits coloré."
          }
        }
      }
    },
    "paywall_caption_coffee": {
      "extractionState": "manual",
      "localizations": {
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Hola! Soc la Dani. Considera desbloquejar partides il·limitades com una manera d'invitar-me a un cafè. Estar ben cafeïnada m'ajuda a continuar construint noves funcionalitats que espere que t'agraden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hi! I'm Dani. Consider unlocking Unlimited Plays as a way to get me a coffee. Being caffeinated helps me keep building new features that I hope you'll love."
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "Hi! I'm Dani. Consider unlocking Unlimited Plays as a way to get me a coffee. Being caffeinated helps me keep building new features that I hope you'll love."
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Hi! I'm Dani. Consider unlocking Unlimited Plays as a way to get me a coffee. Being caffeinated helps me keep building new features that I hope you'll love."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Hi! I'm Dani. Consider unlocking Unlimited Plays as a way to get me a coffee. Being caffeinated helps me keep building new features that I hope you'll love."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¡Hola! Soy Dani. Plantéate desbloquear partidas ilimitadas como una forma de invitarme a un café. Estar bien cafeinada me ayuda a seguir construyendo nuevas funciones que espero que te encanten."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Hi! Ich bin Dani. Schalte Unbegrenzte Spiele frei und spendier mir einen Kaffee. Koffein hilft mir, neue Features zu bauen, die du hoffentlich lieben wirst."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Hoi! Ik ben Dani. Overweeg Onbeperkt spelen te ontgrendelen als een manier om me een koffie te trakteren. Cafeïne helpt me nieuwe functies te bouwen waarvan ik hoop dat je ze geweldig vindt."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ciao! Sono Dani. Considera di sbloccare Partite illimitate per offrirmi un caffè. La caffeina mi aiuta a creare nuove funzioni che spero ti piaceranno."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Salut ! Je suis Dani. Pense à débloquer Parties illimitées pour m'offrir un café. La caféine m'aide à créer de nouvelles fonctionnalités qui, je l'espère, te plairont."
          }
        }
      }
    },
