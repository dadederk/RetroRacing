    "settings_leaderboard_watch_sign_in_required": {
      "extractionState": "manual",
      "localizations": {
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Inicia la sessió a Game Center des del teu iPhone per enviar puntuacions des del rellotge."
          }
        },
        "en": {
