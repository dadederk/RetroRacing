        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Riproduce brevi impulsi per posizione di corsia; l'impulso attivo indica una corsia sicura."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Joue de courtes pulsations par position de voie ; une pulsation active indique une voie sûre."
          }
        }
      }
