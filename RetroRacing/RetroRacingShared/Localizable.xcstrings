    "paywall_limit_notice": {
      "extractionState": "manual",
      "localizations": {
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Parada als boxes! Has esgotat totes les partides d'avui. Torna demà per a més partides gratuïtes. O fes-te il·limitat: un cafè per a mi, partides il·limitades per a tu!"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pit stop! You've used up all your plays for today. Come back tomorrow for more free plays. Or go unlimited: One coffee for me, unlimited plays for you!"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¡Parada en boxes! Has agotado todas tus partidas de hoy. Vuelve mañana para más partidas gratuitas. ¿O hazte ilimitado? Un café para mí, partidas ilimitadas para ti."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Pit stop! You've used up all your plays for today. Come back tomorrow for more free plays. Or go unlimited: One coffee for me, unlimited plays for you!"
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "Pit stop! You've used up all your plays for today. Come back tomorrow for more free plays. Or go unlimited: One coffee for me, unlimited plays for you!"
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Pit stop! You've used up all your plays for today. Come back tomorrow for more free plays. Or go unlimited: One coffee for me, unlimited plays for you!"
          }
        }
      }
    },
    "paywall_stay_free_body": {
      "extractionState": "manual",
      "localizations": {
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Cap problema! El teu límit diari es reinicia a mitjanit. Només cal esperar una miqueta per a tornar a gaudir del joc. O continua jugant tot el que vulgues al teu Apple Watch! Fins demà!"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No problem! Your daily limit resets at midnight. Just wait a bit to enjoy the game again. Or keep playing as much as you want on your Apple Watch! See you tomorrow!"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¡Sin problema! Tu límite diario se reinicia a medianoche. Solo tienes que esperar un poco para volver a disfrutar del juego. ¡O juega todo lo que quieras en tu Apple Watch! ¡Hasta mañana!"
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "No problem! Your daily limit resets at midnight. Just wait a bit to enjoy the game again. Or keep playing as much as you want on your Apple Watch! See you tomorrow!"
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "No problem! Your daily limit resets at midnight. Just wait a bit to enjoy the game again. Or keep playing as much as you want on your Apple Watch! See you tomorrow!"
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "No problem! Your daily limit resets at midnight. Just wait a bit to enjoy the game again. Or keep playing as much as you want on your Apple Watch! See you tomorrow!"
          }
        }
      }
    },
