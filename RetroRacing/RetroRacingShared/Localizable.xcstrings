    "tutorial_audio_mode_description_arpeggio": {
      "extractionState": "manual",
      "localizations": {
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Reproduïx els carrils segurs una nota darrere d'una altra, d'esquerra a dreta."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Plays safe lanes one note after another from left to right."
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "Plays safe lanes one note after another from left to right."
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Plays safe lanes one note after another from left to right."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Plays safe lanes one note after another from left to right."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Reproduce los carriles seguros una nota tras otra, de izquierda a derecha."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Spielt sichere Spuren nacheinander von links nach rechts ab."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Speelt veilige banen één voor één af, van links naar rechts."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Riproduce le corsie sicure una nota dopo l'altra, da sinistra a destra."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Joue les voies sûres une note après l'autre, de gauche à droite."
          }
        }
      }
    },
    "tutorial_audio_mode_description_chord": {
      "extractionState": "manual",
      "localizations": {
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Reproduïx tots els carrils segurs alhora com un acord."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Plays all safe lanes at once as a chord."
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "Plays all safe lanes at once as a chord."
          }
        },
        "en-CA": {
