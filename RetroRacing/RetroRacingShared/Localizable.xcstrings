    "settings_controller_footnote": {
      "extractionState": "manual",
      "localizations": {
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Els botons remapejats substituïxen les assignacions predeterminades de D-pad/Menú per a eixes accions. El stick esquerre continua com a suport esquerra/dreta. Les tecles de fletxa continuen actives al Mac."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Remapped buttons replace the default D-pad/Menu bindings for those actions. The left stick remains a left/right backup. Arrow keys remain active on Mac."
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "Remapped buttons replace the default D-pad/Menu bindings for those actions. The left stick remains a left/right backup. Arrow keys remain active on Mac."
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Remapped buttons replace the default D-pad/Menu bindings for those actions. The left stick remains a left/right backup. Arrow keys remain active on Mac."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Remapped buttons replace the default D-pad/Menu bindings for those actions. The left stick remains a left/right backup. Arrow keys remain active on Mac."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los botones remapeados sustituyen las asignaciones predeterminadas de D-pad/Menú para esas acciones. El stick izquierdo sigue como respaldo izquierda/derecha. Las teclas de flecha siguen activas en Mac."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Neu zugewiesene Tasten ersetzen die Standard-D-pad/Menü-Belegungen für diese Aktionen. Der linke Stick bleibt als Links/Rechts-Backup. Pfeiltasten bleiben auf dem Mac aktiv."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Hertoegewezen knoppen vervangen de standaard D-pad/Menu-toewijzingen voor die acties. De linker stick blijft als links/rechts-back-up. Pijltjestoetsen blijven actief op Mac."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I pulsanti rimappati sostituiscono le assegnazioni predefinite di D-pad/Menu per quelle azioni. Lo stick sinistro resta come backup sinistra/destra. I tasti freccia restano attivi su Mac."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les boutons remappés remplacent les assignations D-pad/Menu par défaut pour ces actions. Le stick gauche reste une option gauche/droite. Les touches fléchées restent actives sur Mac."
          }
        }
      }
    },
