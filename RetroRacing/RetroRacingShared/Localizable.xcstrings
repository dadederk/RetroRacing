    "tutorial_audio_move_style_description_haptics": {
      "extractionState": "manual",
      "localizations": {
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Reproduïx vibració d'èxit si el carril és segur i vibració de moviment si no ho és."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Plays a success haptic for a safe lane and a move haptic for an unsafe lane."
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "Plays a success haptic for a safe lane and a move haptic for an unsafe lane."
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Plays a success haptic for a safe lane and a move haptic for an unsafe lane."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Plays a success haptic for a safe lane and a move haptic for an unsafe lane."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Reproduce háptica de éxito si el carril es seguro y háptica de movimiento si no lo es."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Spielt ein Erfolgs-Haptik-Feedback bei sicherer Spur und ein Bewegungs-Haptik-Feedback bei unsicherer Spur."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Speelt haptische feedback bij succes voor een veilige baan en beweging voor een onveilige baan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Riproduce feedback aptico di successo se la corsia è sicura e di movimento se non lo è."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Joue un retour haptique de succès pour une voie sûre et un retour de mouvement pour une voie dangereuse."
          }
        }
      }
    },
    "tutorial_audio_move_style_description_lane_and_safety": {
      "extractionState": "manual",
      "localizations": {
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Reproduïx la confirmació de carril i tot seguit el to d'èxit o error."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Plays lane confirmation followed by a success or fail tone."
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "Plays lane confirmation followed by a success or fail tone."
          }
        },
        "en-CA": {
          "stringUnit": {
