    "tutorial_audio_mode_description_lane_pulses": {
      "extractionState": "manual",
      "localizations": {
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Reproduïx polsos curts per posició de carril; el pols actiu indica un carril segur."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Plays short pulses in lane slots; an active pulse marks a safe lane."
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "Plays short pulses in lane slots; an active pulse marks a safe lane."
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
