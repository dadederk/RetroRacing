    "debug_simulate_premium_footer": {
      "extractionState": "manual",
      "localizations": {
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Per defecte usa el comportament de producció. Partides il·limitades força l'accés complet. Freemium simula que no s'ha comprat Partides il·limitades."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Default uses production behavior. Unlimited Plays forces full access. Freemium simulates that Unlimited Plays has not been purchased."
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "Default uses production behavior. Unlimited Plays forces full access. Freemium simulates that Unlimited Plays has not been purchased."
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Default uses production behavior. Unlimited Plays forces full access. Freemium simulates that Unlimited Plays has not been purchased."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Default uses production behavior. Unlimited Plays forces full access. Freemium simulates that Unlimited Plays has not been purchased."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Predeterminado usa el comportamiento de producción. Partidas ilimitadas fuerza el acceso completo. Freemium simula que no se ha comprado Partidas ilimitadas."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Standard nutzt Produktionsverhalten. Unbegrenzte Spiele erzwingt vollen Zugriff. Freemium simuliert, dass Unbegrenzte Spiele nicht gekauft wurden."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Standaard gebruikt productiegedrag. Onbeperkt spelen forceert volledige toegang. Freemium simuleert dat Onbeperkt spelen niet is gekocht."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Predefinito usa il comportamento di produzione. Partite illimitate forza l'accesso completo. Freemium simula che Partite illimitate non sia stato acquistato."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Par défaut, comportement de production. Parties illimitées force l'accès complet. Freemium simule que Parties illimitées n'a pas été acheté."
          }
        }
      }
    },
