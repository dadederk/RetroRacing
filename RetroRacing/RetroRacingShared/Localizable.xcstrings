    "about_ammec_footer": {
      "extractionState": "manual",
      "localizations": {
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "El 10% dels ingressos es destinen a AMMEC, una associació que promou l'autonomia i la integració social de persones amb discapacitats físiques, donant suport a les famílies i fomentant la comunitat."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "10% of proceeds go to AMMEC, an association that promotes autonomy and social integration for people with physical disabilities, supporting families and fostering community."
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "10% of proceeds go to AMMEC, an association that promotes autonomy and social integration for people with physical disabilities, supporting families and fostering community."
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "10% of proceeds go to AMMEC, an association that promotes autonomy and social integration for people with physical disabilities, supporting families and fostering community."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "10% of proceeds go to AMMEC, an association that promotes autonomy and social integration for people with physical disabilities, supporting families and fostering community."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El 10% de los ingresos se destinan a AMMEC, una asociación que promueve la autonomía e integración social de personas con discapacidades físicas, apoyando a las familias y fomentando la comunidad."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "10 % der Einnahmen gehen an AMMEC, einen Verein, der Autonomie und soziale Integration für Menschen mit körperlichen Behinderungen fördert, Familien unterstützt und Gemeinschaft stärkt."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "10% van de opbrengsten gaat naar AMMEC, een vereniging die autonomie en sociale integratie voor mensen met een lichamelijke beperking bevordert, gezinnen ondersteunt en gemeenschap versterkt."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il 10% dei ricavi va ad AMMEC, un'associazione che promuove l'autonomia e l'integrazione sociale delle persone con disabilità fisiche, sostenendo le famiglie e favorendo la comunità."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "10 % des recettes vont à AMMEC, une association qui promeut l'autonomie et l'intégration sociale des personnes en situation de handicap physique, en soutenant les familles et en renforçant la communauté."
          }
        }
      }
    },
