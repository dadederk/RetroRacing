    "settings_controls_ios": {
      "extractionState": "manual",
      "localizations": {
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "• Llisca cap a l'esquerra o la dreta per moure.\n• Toca la meitat esquerra o dreta de la pantalla.\n• Fes servir les tecles de fletxa esquerra i dreta amb un teclat connectat.\n• Amb un comandament, el D-pad i el stick esquerre mouen per defecte; pots remapejar botons en Comandament."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "• Swipe left or right to move.\n• Tap the left or right half of the screen.\n• Use the left and right arrow keys when a keyboard is connected.\n• With a controller, the D-pad and left stick move by default; you can remap buttons in Controller settings."
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "• Swipe left or right to move.\n• Tap the left or right half of the screen.\n• Use the left and right arrow keys when a keyboard is connected.\n• With a controller, the D-pad and left stick move by default; you can remap buttons in Controller settings."
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "• Swipe left or right to move.\n• Tap the left or right half of the screen.\n• Use the left and right arrow keys when a keyboard is connected.\n• With a controller, the D-pad and left stick move by default; you can remap buttons in Controller settings."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "• Swipe left or right to move.\n• Tap the left or right half of the screen.\n• Use the left and right arrow keys when a keyboard is connected.\n• With a controller, the D-pad and left stick move by default; you can remap buttons in Controller settings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "• Desliza a la izquierda o derecha para mover.\n• Toca la mitad izquierda o derecha de la pantalla.\n• Usa las teclas de flecha con un teclado conectado.\n• Con un mando, el D-pad y el stick izquierdo mueven por defecto; puedes remapear botones en los ajustes de Mando."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "• Wische links oder rechts zum Bewegen.\n• Tippe auf die linke oder rechte Bildschirmhälfte.\n• Nutze die Pfeiltasten links und rechts bei angeschlossener Tastatur.\n• Mit einem Controller bewegen D-pad und linker Stick standardmäßig; Tasten kannst du in den Controller-Einstellungen neu belegen."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "• Veeg links of rechts om te bewegen.\n• Tik op de linker of rechter helft van het scherm.\n• Gebruik de pijltjestoetsen links en rechts wanneer een toetsenbord is aangesloten.\n• Met een controller bewegen de D-pad en linker stick standaard; je kunt knoppen opnieuw toewijzen in Controller-instellingen."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "• Scorri a sinistra o a destra per muoverti.\n• Tocca la metà sinistra o destra dello schermo.\n• Usa i tasti freccia sinistra e destra con una tastiera collegata.\n• Con un controller, D-pad e stick sinistro muovono per impostazione predefinita; puoi rimappare i pulsanti nelle impostazioni Controller."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "• Glisse à gauche ou à droite pour te déplacer.\n• Touche la moitié gauche ou droite de l'écran.\n• Utilise les touches fléchées gauche et droite quand un clavier est connecté.\n• Avec une manette, le D-pad et le stick gauche déplacent par défaut ; tu peux remapper les boutons dans Réglages Manette."
          }
        }
      }
    },
    "settings_controls_macos": {
      "extractionState": "manual",
      "localizations": {
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "• Fes servir les tecles de fletxa esquerra i dreta del teclat per moure.\n• Clica a la meitat esquerra o dreta de la finestra amb el trackpad o el ratolí.\n• Prem la barra espaiadora per pausar o reprendre.\n• Amb un comandament, el D-pad i el stick esquerre mouen per defecte; pots remapejar botons en Comandament."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "• Use the left and right arrow keys on the keyboard to move.\n• Click the left or right half of the window with the trackpad or mouse.\n• Press the space bar to pause or resume.\n• With a controller, the D-pad and left stick move by default; you can remap buttons in Controller settings."
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "• Use the left and right arrow keys on the keyboard to move.\n• Click the left or right half of the window with the trackpad or mouse.\n• Press the space bar to pause or resume.\n• With a controller, the D-pad and left stick move by default; you can remap buttons in Controller settings."
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "• Use the left and right arrow keys on the keyboard to move.\n• Click the left or right half of the window with the trackpad or mouse.\n• Press the space bar to pause or resume.\n• With a controller, the D-pad and left stick move by default; you can remap buttons in Controller settings."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "• Use the left and right arrow keys on the keyboard to move.\n• Click the left or right half of the window with the trackpad or mouse.\n• Press the space bar to pause or resume.\n• With a controller, the D-pad and left stick move by default; you can remap buttons in Controller settings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "• Usa las teclas de flecha izquierda y derecha del teclado para mover.\n• Haz clic en la mitad izquierda o derecha de la ventana con el trackpad o el ratón.\n• Pulsa la barra espaciadora para pausar o reanudar.\n• Con un mando, el D-pad y el stick izquierdo mueven por defecto; puedes remapear botones en los ajustes de Mando."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "• Nutze die Pfeiltasten links und rechts auf der Tastatur zum Bewegen.\n• Klicke mit Trackpad oder Maus auf die linke oder rechte Fensterhälfte.\n• Drücke die Leertaste zum Pausieren oder Fortsetzen.\n• Mit einem Controller bewegen D-pad und linker Stick standardmäßig; Tasten kannst du in den Controller-Einstellungen neu belegen."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "• Gebruik de pijltjestoetsen links en rechts op het toetsenbord om te bewegen.\n• Klik op de linker of rechter helft van het venster met trackpad of muis.\n• Druk op de spatiebalk om te pauzeren of hervatten.\n• Met een controller bewegen de D-pad en linker stick standaard; je kunt knoppen opnieuw toewijzen in Controller-instellingen."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "• Usa i tasti freccia sinistra e destra sulla tastiera per muoverti.\n• Clicca sulla metà sinistra o destra della finestra con trackpad o mouse.\n• Premi la barra spaziatrice per mettere in pausa o riprendere.\n• Con un controller, D-pad e stick sinistro muovono per impostazione predefinita; puoi rimappare i pulsanti nelle impostazioni Controller."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "• Utilise les touches fléchées gauche et droite du clavier pour te déplacer.\n• Clique sur la moitié gauche ou droite de la fenêtre avec le trackpad ou la souris.\n• Appuie sur la barre d'espace pour mettre en pause ou reprendre.\n• Avec une manette, le D-pad et le stick gauche déplacent par défaut ; tu peux remapper les boutons dans Réglages Manette."
          }
        }
      }
    },
    "settings_controls_tvos": {
      "extractionState": "manual",
      "localizations": {
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "• Llisca a l'esquerra o a la dreta amb el control remot Siri per moure.\n• Fes clic al botó de reproducció per confirmar.\n• Amb un comandament, pots remapejar botons en les opcions de Comandament."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "• Swipe left or right on the Siri Remote to move.\n• Press the play button to select.\n• With a controller, you can remap button bindings in Controller settings."
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "• Swipe left or right on the Siri Remote to move.\n• Press the play button to select.\n• With a controller, you can remap button bindings in Controller settings."
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "• Swipe left or right on the Siri Remote to move.\n• Press the play button to select.\n• With a controller, you can remap button bindings in Controller settings."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "• Swipe left or right on the Siri Remote to move.\n• Press the play button to select.\n• With a controller, you can remap button bindings in Controller settings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "• Desliza a la izquierda o derecha con el mando Siri para mover.\n• Pulsa el botón de reproducción para seleccionar.\n• Con un mando, puedes remapear botones en los ajustes de Mando."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "• Wische mit der Siri Remote links oder rechts zum Bewegen.\n• Drücke die Play-Taste zum Auswählen.\n• Mit einem Controller kannst du Tasten in den Controller-Einstellungen neu belegen."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "• Veeg links of rechts met de Siri Remote om te bewegen.\n• Druk op de afspeelknop om te selecteren.\n• Met een controller kun je knoppen opnieuw toewijzen in Controller-instellingen."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "• Scorri a sinistra o a destra con il telecomando Siri per muoverti.\n• Premi il pulsante play per selezionare.\n• Con un controller puoi rimappare i pulsanti nelle impostazioni Controller."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "• Glisse à gauche ou à droite avec la Siri Remote pour te déplacer.\n• Appuie sur le bouton lecture pour sélectionner.\n• Avec une manette, tu peux remapper les boutons dans Réglages Manette."
          }
        }
      }
    },
    "settings_controls_watchos": {
      "extractionState": "manual",
      "localizations": {
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "• Gira la Digital Crown cap amunt per moure't a la dreta i cap avall per moure't a l'esquerra.\n• Toca la part esquerra de la pantalla per moure't a l'esquerra i la dreta per moure't a la dreta.\n• Llisca cap a l'esquerra per moure't a l'esquerra i cap a la dreta per moure't a la dreta."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "• Rotate the Digital Crown up to move right and down to move left.\n• Tap the left side of the screen to move left and the right side to move right.\n• Swipe left to move left and right to move right."
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "• Rotate the Digital Crown up to move right and down to move left.\n• Tap the left side of the screen to move left and the right side to move right.\n• Swipe left to move left and right to move right."
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "• Rotate the Digital Crown up to move right and down to move left.\n• Tap the left side of the screen to move left and the right side to move right.\n• Swipe left to move left and right to move right."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "• Rotate the Digital Crown up to move right and down to move left.\n• Tap the left side of the screen to move left and the right side to move right.\n• Swipe left to move left and right to move right."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "• Gira la Digital Crown hacia arriba para moverte a la derecha y hacia abajo para moverte a la izquierda.\n• Toca la parte izquierda de la pantalla para moverte a la izquierda y la derecha para moverte a la derecha.\n• Desliza a la izquierda para moverte a la izquierda y a la derecha para moverte a la derecha."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "• Drehe die Digital Crown nach oben für rechts und nach unten für links.\n• Tippe links auf den Bildschirm für links und rechts für rechts.\n• Wische links zum Bewegen nach links und rechts zum Bewegen nach rechts."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "• Draai de Digital Crown omhoog om naar rechts te gaan en omlaag om naar links te gaan.\n• Tik op de linkerkant van het scherm om naar links te gaan en op de rechterkant om naar rechts te gaan.\n• Veeg naar links om naar links te gaan en naar rechts om naar rechts te gaan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "• Ruota la Digital Crown verso l'alto per andare a destra e verso il basso per andare a sinistra.\n• Tocca il lato sinistro dello schermo per andare a sinistra e il destro per andare a destra.\n• Scorri a sinistra per andare a sinistra e a destra per andare a destra."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "• Tourne la Digital Crown vers le haut pour aller à droite et vers le bas pour aller à gauche.\n• Touche le côté gauche de l'écran pour aller à gauche et le côté droit pour aller à droite.\n• Glisse à gauche pour aller à gauche et à droite pour aller à droite."
          }
        }
      }
    },
