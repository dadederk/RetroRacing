    "paywall_stay_free_body": {
      "extractionState": "manual",
      "localizations": {
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Cap problema! El límit diari es reinicia a mitjanit. Continua jugant tant com vulguis a l'Apple Watch o fes una cursa gratis amb un amic amb SharePlay!"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No worries! Your daily limit resets at midnight. Keep playing as much as you want on your Apple Watch or race a friend for free with SharePlay!"
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "No worries! Your daily limit resets at midnight. Keep playing as much as you want on your Apple Watch or race a friend for free with SharePlay!"
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
